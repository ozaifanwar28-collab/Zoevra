  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family: 'Poppins', sans-serif;
    }body{
  background: linear-gradient(135deg, #000000, #1a1a1a);
  color: white;
}

header{
  text-align:center;
