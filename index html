}

.highlight{
  color:#00f7ff;
}

.btn{
  margin-top:25px;
  padding:12px 25px;
  border:none;
  border-radius:30px;
  background: linear-gradient(90deg, #00f7ff, #ff00c8);
  color:white;
  font-size:16px;
  cursor:pointer;
  transition:0.3s;
}

.btn:hover{
  transform: scale(1.1);
}

footer{
